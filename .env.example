# === OpenAI API 配置（STT 转写 + LLM 纪要）===
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# === STT 配置 ===
# Whisper 模型: whisper-1
STT_MODEL=whisper-1
# 转写语言（留空自动检测）
STT_LANGUAGE=zh

# === LLM 配置 ===
# 纪要生成模型: gpt-4o-mini（推荐性价比） / gpt-4o / deepseek-chat
LLM_MODEL=gpt-4o-mini

# === DeepSeek API（可选，作为低成本备选）===
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === 应用配置 ===
# 后端服务端口（留空自动分配）
BACKEND_PORT=
# 数据存储目录（留空使用默认 %APPDATA%\MemoApp）
DATA_DIR=
